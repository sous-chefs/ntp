# Managed by Chef. Local changes will be overwritten.
<% cfg = @ntp_config -%>
tinker <%= cfg[:tinker].flatten.join(' ') %>
statsdir <%= cfg[:statsdir] %>
leapfile <%= cfg[:leapfile] %>
tos maxdist <%= cfg[:tos_maxdist] %>
driftfile <%= cfg[:driftfile] %>
<% if cfg[:logfile] -%>
logfile <%= cfg[:logfile] %>
<% end -%>
<% if cfg[:statistics] -%>
statistics loopstats peerstats clockstats
filegen loopstats file loopstats type day enable
filegen peerstats file peerstats type day enable
filegen clockstats file clockstats type day enable
<% end -%>
<% cfg[:ignore].each do |ignore| -%>
interface ignore <%= ignore %>
<% end -%>
<% cfg[:listen].each do |listen| -%>
interface listen <%= listen %>
<% end -%>
<% if cfg[:listen].any? && !cfg[:listen].include?('127.0.0.1') -%>
interface listen 127.0.0.1
<% end -%>
<% if cfg[:logconfig] -%>
logconfig =<%= cfg[:logconfig] %>
<% end -%>
<%= cfg[:monitor] ? 'enable monitor' : 'disable monitor' %>
<% cfg[:peers].each do |peer| -%>
<% next if [cfg[:ipaddress], cfg[:fqdn]].include?(peer) -%>
peer <%= peer %><% if cfg[:peer][:key] -%> key <%= cfg[:peer][:key] %><% end -%><% if cfg[:peer][:use_iburst] -%> iburst<% end -%><% if cfg[:peer][:use_burst] -%> burst<% end -%> minpoll <%= cfg[:peer][:minpoll] %> maxpoll <%= cfg[:peer][:maxpoll] %>
restrict <%= peer %> nomodify
<% end -%>
<% cfg[:servers].each do |server| -%>
<% next if [cfg[:ipaddress], cfg[:fqdn]].include?(server) -%>
server <%= server %><% if cfg[:server][:use_iburst] -%> iburst<% end -%><% if cfg[:server][:use_burst] -%> burst<% end -%> minpoll <%= cfg[:server][:minpoll] %> maxpoll <%= cfg[:server][:maxpoll] %><% if cfg[:server][:prefer] == server -%> prefer<% end -%>
restrict <%= server %> nomodify notrap noquery
<% end -%>
<% cfg[:pools].each do |pool| -%>
pool <%= pool %><% if cfg[:server][:use_iburst] -%> iburst<% end -%><% if cfg[:server][:use_burst] -%> burst<% end -%> minpoll <%= cfg[:server][:minpoll] %> maxpoll <%= cfg[:server][:maxpoll] %><% if cfg[:server][:prefer] == pool -%> prefer<% end -%>
restrict <%= pool %> nomodify notrap noquery
<% end -%>
restrict default <%= cfg[:restrict_default] %>
restrict 127.0.0.1<% if cfg[:localhost_noquery] -%> noquery<% end -%>
restrict -6 default <%= cfg[:restrict_default] %>
restrict -6 ::1<% if cfg[:localhost_noquery] -%> noquery<% end -%>
<% cfg[:restrictions].each do |restriction| -%>
restrict <%= restriction %>
<% end -%>
<% if cfg[:orphan][:enabled] -%>
tos orphan <%= cfg[:orphan][:stratum] %>
<% end -%>
<% if cfg[:keys] -%>
keys <%= cfg[:keys] %>
<% end -%>
<% if cfg[:trustedkey] -%>
trustedkey <%= cfg[:trustedkey] %>
<% end -%>
<% if cfg[:requestkey] -%>
requestkey <%= cfg[:requestkey] %>
<% end -%>
<% if cfg[:dscp] -%>
dscp <%= cfg[:dscp] %>
<% end -%>
